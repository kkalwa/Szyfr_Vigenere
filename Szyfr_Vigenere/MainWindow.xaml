<Window x:Class="Szyfr_Vigenere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Szyfr_Vigenere"
        mc:Ignorable="d"
        Title="Vigenere" Height="auto" Width="auto" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <Style x:Key="HorizontalListView" TargetType="ListView">
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <StackPanel Grid.Column="0"
                    Grid.Row="1">
            <TextBlock Text="Wiadomość do zaszyfrowania:"/>
            <TextBox Height="100"
                     Width="250"
                     TextWrapping="Wrap"
                     Text="{Binding TextToEncrypt, UpdateSourceTrigger=PropertyChanged}">
            </TextBox>
            <TextBlock Text="Klucz:"/>
            <TextBox Width="250"
                     Text="{Binding KeyText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Szyfrogram:"/>
            <TextBlock Width="250"
                     Height="100"
                       TextWrapping="Wrap"
                     Text="{Binding EncryptedText}"/>
        </StackPanel>
        
        <ListView Grid.Column="1"
                  Grid.Row="1"
                  ItemsSource="{Binding RowNumbers}">
        </ListView>

        <ListView Grid.Column="2"
                  ItemsSource="{Binding CharactersCollection}"
                  Style="{StaticResource HorizontalListView}">
        </ListView>

        <ListView Grid.Column="2"
                  Grid.Row="1"
                  ItemsSource="{Binding RowCollections}"
                  FontSize="7">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ListView ItemsSource="{Binding}" Style="{StaticResource HorizontalListView}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Window>
